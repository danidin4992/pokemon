# --- Required for sending the daily digest ---
RESEND_API_KEY=re_xxxxxxxxxxxx
DIGEST_TO_EMAIL=dani.smrn@gmail.com
DIGEST_FROM_EMAIL=onboarding@resend.dev

# --- Server ---
PORT=3737

# --- Production / Railway only ---
# Set AUTH_PASSWORD to gate the UI behind Basic Auth.
# Leave blank for local dev (no auth).
AUTH_PASSWORD=
AUTH_USERNAME=admin

# Override cron schedule (default: "0 8 * * *" = daily 08:00).
# Set to empty string "" to disable in-process cron.
# CRON_SCHEDULE=0 8 * * *
# CRON_TIMEZONE=Asia/Jerusalem

# Override storage paths (Railway volume mount goes to /data)
# DB_PATH=/data/pokemon.db
# DATA_DIR=/data

# --- Per-listing "Notify me" — POSTs to your phone via ntfy.sh (or any JSON webhook) ---
# Multi-recipient (recommended): JSON array of { key, label, webhook }.
# Each recipient gets their own phone alerts. Users pick who they are in the UI.
# NOTIFY_RECIPIENTS='[{"key":"daniel","label":"Daniel","webhook":"https://ntfy.sh/pokemon-danidin4992-a7k9m3xq"},{"key":"asaf","label":"Assaf","webhook":"https://ntfy.sh/pokemon-asaf-xxxx"}]'
#
# Single-recipient legacy fallback (used only if NOTIFY_RECIPIENTS is unset):
# NOTIFY_WEBHOOK_URL=https://ntfy.sh/your-topic

# --- Warm refresh cron ---
# When set, re-scrapes ONLY searches that have hot listings or listings
# ending within 24h. Off by default while still on scraping — frequent
# re-hits of eBay search pages increase shadow-content risk. Turn on
# after switching to the eBay Buy Browse API (EBAY_API_TOKEN).
# WARM_REFRESH_CRON=*/90 * * * *

# --- eBay Buy Browse API (production) ---
# App keys from https://developer.ebay.com/my/keys
# EBAY_APP_ID=DanielSm-...-PRD-...
# EBAY_CERT_ID=PRD-...
# EBAY_DEV_ID=<uuid>
# EBAY_MARKETPLACE=EBAY_US  # optional, default EBAY_US
# Flip to "api" once smoke-tested. Otherwise the app keeps using the scraper.
# EBAY_DATA_SOURCE=api
